# --- БД --------------------------------------------------------------------
# Используется async-драйвер (asyncpg). Формат:
#   postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
RIR2LOCALDB_DATABASE_URL=postgresql+asyncpg://rir2localdb:rir2localdb@localhost:5432/rir2localdb

# Отдельная БД для тестов sync/state и etl (testcontainers оставляем на CI).
# Создать заранее: `sudo -u postgres psql -c "CREATE DATABASE rir2localdb_test OWNER rir2localdb;"`.
# Если переменная не задана — соответствующие тесты пропускаются.
RIR2LOCALDB_TEST_DATABASE_URL=postgresql+asyncpg://rir2localdb:rir2localdb@localhost:5432/rir2localdb_test

# --- Файлы и кэш -----------------------------------------------------------
# Куда складывать скачанные сырые файлы. По умолчанию — рядом с проектом.
# В проде задайте, например, /var/lib/rir2localdb.
RIR2LOCALDB_DATA_DIR=./data

# Сколько последних успешных sync run'ов хранить локально (старые подкаталоги
# удаляет команда `rir2localdb gc`).
RIR2LOCALDB_KEEP_RUNS=7

# --- Сеть ------------------------------------------------------------------
RIR2LOCALDB_HTTP_TIMEOUT=60
RIR2LOCALDB_HTTP_MAX_CONNECTIONS=10
RIR2LOCALDB_HTTP_RETRIES=3

# --- Логи ------------------------------------------------------------------
# debug | info | warning | error
RIR2LOCALDB_LOG_LEVEL=info
# json (для prod) | console (для dev)
RIR2LOCALDB_LOG_FORMAT=console

# --- Tier'ы ----------------------------------------------------------------
# Какие слои данных включены при `rir2localdb sync` без явного --tier.
# Через запятую: core,rich,arin-rr
RIR2LOCALDB_TIERS_ENABLED=core

# --- ARIN Bulk Whois (опционально, Stage 2) --------------------------------
# Если у вас есть API-ключ от ARIN (получается через ARIN Online после
# принятия их Terms of Use) — впишите его сюда. Иначе оставьте пустым:
# ARIN-данные будут только из delegated stats.
RIR2LOCALDB_ARIN_BULK_KEY=

# --- API ------------------------------------------------------------------
RIR2LOCALDB_API_HOST=0.0.0.0
RIR2LOCALDB_API_PORT=8000
